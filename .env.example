# Safe judge default: deterministic synthetic data only.
# The bootstrap scripts force this mode and never start discovery against the
# public internet, outreach, recurring workers, Codex automations, or deploys.
SITEKAPINDA_MODE=mock
SITEKAPINDA_MOCK_DATA_PATH=data/mock_places.json
SITEKAPINDA_DB_PATH=runtime/sitekapinda.sqlite3
SITEKAPINDA_OUTPUT_DIR=runtime/generated
SITEKAPINDA_REPORT_DIR=runtime/reports
SITEKAPINDA_MAX_PER_RUN=12
SITEKAPINDA_MIN_SCORE=60
SITEKAPINDA_SEARCH_LOCATIONS=Example District;Demo Quarter

# Intentionally blank. Real mode is outside the judge quick-start and requires
# the operator to configure an official provider separately and approve it.
SITEKAPINDA_GOOGLE_PLACES_API_KEY=
